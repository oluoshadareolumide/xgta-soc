# Copy to .env and fill in your values

# SQL Server connection string
# Format: mssql+pyodbc://user:password@host/dbname?driver=ODBC+Driver+17+for+SQL+Server
DATABASE_URL=mssql+pyodbc://sa:YourPassword@localhost/xgta_soc?driver=ODBC+Driver+17+for+SQL+Server

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# App
APP_ENV=development
APP_TITLE=XGTA-SOC API
API_V1_PREFIX=/api/v1

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Anthropic API (for AI threat analysis)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
